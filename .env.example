# Copy this to .env and fill in your keys one by one as you create accounts

# ── VAPI (voice AI) ──────────────────────────────
# Sign up: https://vapi.ai
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=pick_any_random_string_here
SALES_ASSISTANT_ID=   # filled automatically by setup-sales-agent.js

# ── TWILIO (phone numbers) ───────────────────────
# Sign up: https://twilio.com
# Buy a Calgary number: +1 (403) or (587) area code
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── STRIPE (billing) ─────────────────────────────
# Sign up: https://stripe.com
# Create a $297/mo recurring product in Stripe dashboard
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── GOOGLE (lead scraping) ────────────────────────
# Sign up: https://console.cloud.google.com
# Enable: Places API — you get $200 free credit/month
GOOGLE_PLACES_API_KEY=

# ── SENDGRID (follow-up emails) ──────────────────
# Sign up: https://sendgrid.com (free: 100 emails/day)
SENDGRID_API_KEY=
FROM_EMAIL=you@yourdomain.com

# ── CAL.COM (appointment booking) ────────────────
# Sign up: https://cal.com (free)
# Clients connect their Google Calendar here
CALCOM_API_KEY=

# ── SERVER ────────────────────────────────────────
# Your hosted server URL (use Railway: https://railway.app)
# For local testing use ngrok: https://ngrok.com
SERVER_URL=https://your-app.railway.app

# ── DEMO ──────────────────────────────────────────
# Your Zoom or Google Meet link for demos
DEMO_ZOOM_LINK=https://zoom.us/j/your-meeting-id
